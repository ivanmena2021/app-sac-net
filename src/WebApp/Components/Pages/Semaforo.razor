@page "/semaforo"
@rendermode InteractiveServer
@inject ISemaforoService SemaforoService
@inject IJSRuntime JS
@using WebApp.Components.Custom

<PageTitle>Semáforo de Alertas — SAC</PageTitle>

<PageHeader Title="🚦 Semáforo de Alertas" Description="Control de plazos por etapa del proceso SAC" />

@if (Home.SharedDatos == null)
{
    <div class="alert alert-warning">⚠️ Primero cargue los datos en la página de <a href="/">Inicio</a>.</div>
}
else
{
    @if (Result == null)
    {
        <button class="btn btn-primary" @onclick="ComputeSemaforo">🔍 Calcular Semáforo</button>
    }
    else
    {
        <!-- Global summary -->
        <div class="row mt-3">
            <div class="col-md-3"><MetricCard Label="Total Avisos Analizados" Value="@Result.TotalAvisos.ToString("N0")" Accent="blue" /></div>
            <div class="col-md-3"><MetricCard Label="🟢 En plazo (Verde)" Value="@Result.Verde.ToString("N0")" Accent="green" /></div>
            <div class="col-md-3"><MetricCard Label="🟡 En riesgo (Ámbar)" Value="@Result.Ambar.ToString("N0")" Accent="amber" /></div>
            <div class="col-md-3"><MetricCard Label="🔴 Vencido (Rojo)" Value="@Result.Rojo.ToString("N0")" Accent="red" /></div>
        </div>

        <!-- Progress bar -->
        <div class="progress mt-3" style="height: 30px;">
            @{
                var total = (double)Result.TotalAvisos;
                var pVerde = total > 0 ? Result.Verde / total * 100 : 0;
                var pAmbar = total > 0 ? Result.Ambar / total * 100 : 0;
                var pRojo = total > 0 ? Result.Rojo / total * 100 : 0;
            }
            <div class="progress-bar bg-success" style="width: @pVerde.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%">@Result.Verde</div>
            <div class="progress-bar bg-warning" style="width: @pAmbar.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%">@Result.Ambar</div>
            <div class="progress-bar bg-danger" style="width: @pRojo.ToString("F1", System.Globalization.CultureInfo.InvariantCulture)%">@Result.Rojo</div>
        </div>

        <!-- By department -->
        <h5 class="mt-4">Estado por Departamento</h5>
        <div class="table-responsive" style="max-height:500px;overflow-y:auto;">
            <table class="table table-sm table-striped table-bordered">
                <thead class="table-primary sticky-top">
                    <tr><th>Departamento</th><th>Total</th><th>🟢 Verde</th><th>🟡 Ámbar</th><th>🔴 Rojo</th><th>% Riesgo</th><th>Estado</th></tr>
                </thead>
                <tbody>
                    @foreach (var kvp in Result.PorDepartamento.OrderByDescending(x => x.Value.Rojo))
                    {
                        var d = kvp.Value;
                        var pctRiesgo = d.Total > 0 ? (double)(d.Ambar + d.Rojo) / d.Total * 100 : 0;
                        var emoji = d.Rojo > d.Total * 0.3 ? "🔴" : d.Ambar > d.Total * 0.3 ? "🟡" : "🟢";
                        <tr>
                            <td>@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(kvp.Key.ToLower())</td>
                            <td class="text-end">@d.Total</td>
                            <td class="text-end text-success">@d.Verde</td>
                            <td class="text-end text-warning">@d.Ambar</td>
                            <td class="text-end text-danger">@d.Rojo</td>
                            <td class="text-end">@($"{pctRiesgo:F1}%")</td>
                            <td class="text-center">@emoji</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <!-- Detail by stage -->
        <h5 class="mt-4">Distribución por Etapa</h5>
        <div class="table-responsive">
            <table class="table table-sm table-bordered">
                <thead class="table-primary">
                    <tr><th>Etapa</th><th>Avisos</th><th>🟢</th><th>🟡</th><th>🔴</th></tr>
                </thead>
                <tbody>
                    @foreach (var etapa in Result.Rows.GroupBy(r => r.Etapa).OrderBy(g => g.Key))
                    {
                        <tr>
                            <td>@etapa.Key</td>
                            <td class="text-end">@etapa.Count()</td>
                            <td class="text-end text-success">@etapa.Count(r => r.Alerta == "verde")</td>
                            <td class="text-end text-warning">@etapa.Count(r => r.Alerta == "ambar")</td>
                            <td class="text-end text-danger">@etapa.Count(r => r.Alerta == "rojo")</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <button class="btn btn-outline-secondary mt-3" @onclick="() => Result = null">🔄 Recalcular</button>
    }
}

<SacFooter />

@code {
    private SemaforoResultDto? Result;

    private void ComputeSemaforo()
    {
        if (Home.SharedDatos == null) return;
        Result = SemaforoService.ComputeSemaforo(Home.SharedDatos);
    }
}

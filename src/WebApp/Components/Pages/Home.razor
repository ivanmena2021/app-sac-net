@page "/"
@rendermode InteractiveServer
@inject IDataProcessorService DataProcessor
@inject IAutoDownloadService AutoDownloader
@using WebApp.Components.Custom

<PageTitle>SAC 2025-2026 — Dashboard</PageTitle>

@if (!IsDataLoaded)
{
    <!-- Hero Banner -->
    <div class="hero">
        <h1>🌾 SAC 2025 — 2026</h1>
        <p>Seguro Agrícola Catastrófico — MIDAGRI</p>
        <p class="text-light opacity-75">Dashboard de monitoreo y generación de reportes</p>
        <small class="text-light opacity-50">@DateTime.Now.ToString("dd/MM/yyyy HH:mm")</small>
    </div>

    <!-- Auto-download option -->
    @if (AutoDownloader.IsConfigured())
    {
        <div class="card mb-3 border-success">
            <div class="card-body text-center">
                <button class="btn btn-success btn-lg px-5" @onclick="AutoDownload" disabled="@IsAutoDownloading">
                    @if (IsAutoDownloading)
                    {
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        <span>@AutoDownloadStatus</span>
                    }
                    else
                    {
                        <span>Actualizar Datos SAC (descarga automatica)</span>
                    }
                </button>
                <p class="text-muted small mt-2 mb-0">Descarga directa desde SISGAQSAC (Rimac) y Agroevaluaciones (La Positiva)</p>
            </div>
        </div>
    }

    <!-- Stepper -->
    <Stepper Steps="@CurrentSteps" />

    <!-- Upload Section -->
    <div class="row mt-4">
        <div class="col-md-6">
            <div class="action-card">
                <h5>📁 1. Archivo MIDAGRI</h5>
                <p class="text-muted">Reporte Listar Todos los Avisos — La Positiva (.xlsx)</p>
                <InputFile OnChange="OnMidagriFileSelected" accept=".xlsx" class="form-control" />
                @if (MidagriFileName != null)
                {
                    <small class="text-success mt-1 d-block">✅ @MidagriFileName</small>
                }
            </div>
        </div>
        <div class="col-md-6">
            <div class="action-card">
                <h5>📁 2. Sistema de Registro de Siniestros</h5>
                <p class="text-muted">Archivo del Sistema de Registro — Rímac (.xlsx)</p>
                <InputFile OnChange="OnSiniestrosFileSelected" accept=".xlsx" class="form-control" />
                @if (SiniestrosFileName != null)
                {
                    <small class="text-success mt-1 d-block">✅ @SiniestrosFileName</small>
                }
            </div>
        </div>
    </div>

    <div class="text-center mt-3">
        @if (MidagriBytes != null && SiniestrosBytes != null)
        {
            <button class="btn btn-primary btn-lg px-5" @onclick="ProcessData" disabled="@IsProcessing">
                @if (IsProcessing)
                {
                    <span class="spinner-border spinner-border-sm me-2"></span>
                    <span>Procesando datos...</span>
                }
                else
                {
                    <span>🚀 Procesar datos</span>
                }
            </button>
        }
        else
        {
            <div class="alert alert-info">📌 Suba ambos archivos para continuar</div>
        }
    </div>

    @if (ErrorMessage != null)
    {
        <div class="alert alert-danger mt-3">@ErrorMessage</div>
    }

    <!-- Info Cards -->
    <div class="row mt-4">
        <div class="col-md-3">
            <div class="action-card text-center">
                <h4>📊</h4>
                <h6>Dashboard Nacional</h6>
                <p class="text-muted small">KPIs y métricas principales del SAC a nivel nacional</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="action-card text-center">
                <h4>📄</h4>
                <h6>Ayuda Memoria</h6>
                <p class="text-muted small">Reportes Nacional y Departamental en Word</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="action-card text-center">
                <h4>🗺️</h4>
                <h6>Mapa de Calor</h6>
                <p class="text-muted small">Visualización geográfica de siniestros</p>
            </div>
        </div>
        <div class="col-md-3">
            <div class="action-card text-center">
                <h4>🔔</h4>
                <h6>Semáforo de Alertas</h6>
                <p class="text-muted small">Control de plazos por etapa del SAC</p>
            </div>
        </div>
    </div>

    <SacFooter />
}
else
{
    <!-- Redirect to Dashboard after data loaded -->
    <PageHeader Title="Datos cargados exitosamente" Description="Use el menú lateral para navegar" />
    <StatusBanner IsDataLoaded="true" Timestamp="@UpdateTimestamp" Source="@DataSource" />

    <div class="row mt-4">
        <div class="col-md-4">
            <a href="/dashboard" class="btn btn-primary btn-lg w-100">📊 Ir al Dashboard</a>
        </div>
        <div class="col-md-4">
            <a href="/reportes" class="btn btn-outline-primary btn-lg w-100">📄 Generar Reportes</a>
        </div>
        <div class="col-md-4">
            <button class="btn btn-outline-secondary btn-lg w-100" @onclick="ResetData">🔄 Cargar nuevos datos</button>
        </div>
    </div>

    <SacFooter />
}

@code {
    // Static shared state (accessible from all pages)
    public static DatosNacionalesDto? SharedDatos { get; set; }
    public static string? UpdateTimestamp { get; set; }
    public static string? DataSource { get; set; }
    public static bool IsDataLoaded => SharedDatos != null;

    private byte[]? MidagriBytes;
    private byte[]? SiniestrosBytes;
    private string? MidagriFileName;
    private string? SiniestrosFileName;
    private string? ErrorMessage;
    private bool IsProcessing;

    private List<Stepper.StepItem> CurrentSteps = new()
    {
        new() { Label = "Archivo MIDAGRI", Status = "pending" },
        new() { Label = "Archivo Siniestros", Status = "pending" },
        new() { Label = "Procesando", Status = "pending" },
        new() { Label = "Listo", Status = "pending" },
    };

    private async Task<byte[]> ReadFileToBytes(IBrowserFile file)
    {
        // Read file in chunks with large buffer to avoid SignalR truncation
        const long maxSize = 50 * 1024 * 1024; // 50 MB
        await using var stream = file.OpenReadStream(maxAllowedSize: maxSize);
        using var ms = new MemoryStream();
        var buffer = new byte[512 * 1024]; // 512 KB buffer
        int bytesRead;
        while ((bytesRead = await stream.ReadAsync(buffer, 0, buffer.Length)) > 0)
        {
            ms.Write(buffer, 0, bytesRead);
        }
        return ms.ToArray();
    }

    private async Task OnMidagriFileSelected(InputFileChangeEventArgs e)
    {
        MidagriFileName = e.File.Name;
        MidagriBytes = await ReadFileToBytes(e.File);
        CurrentSteps[0].Status = "done";
        if (SiniestrosBytes != null) CurrentSteps[1].Status = "done";
    }

    private async Task OnSiniestrosFileSelected(InputFileChangeEventArgs e)
    {
        SiniestrosFileName = e.File.Name;
        SiniestrosBytes = await ReadFileToBytes(e.File);
        CurrentSteps[1].Status = "done";
        if (MidagriBytes != null) CurrentSteps[0].Status = "done";
    }

    private async Task ProcessData()
    {
        if (MidagriBytes == null || SiniestrosBytes == null) return;
        IsProcessing = true;
        ErrorMessage = null;
        CurrentSteps[2].Status = "active";
        StateHasChanged();

        try
        {
            var mb = MidagriBytes;
            var sb = SiniestrosBytes;

            await Task.Run(() =>
            {
                using var ms1 = new MemoryStream(mb);
                using var ms2 = new MemoryStream(sb);
                SharedDatos = DataProcessor.ProcessDynamicData(ms1, ms2);
            });

            // Store bytes for Python API report generation
            Infrastructure.PythonApi.PythonApiReportService.SetUploadedFiles(mb, sb);
            UpdateTimestamp = DateTime.Now.ToString("dd/MM/yyyy HH:mm:ss");
            DataSource = "manual";
            CurrentSteps[2].Status = "done";
            CurrentSteps[3].Status = "done";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error al procesar: {ex.Message}";
            CurrentSteps[2].Status = "error";
        }
        finally
        {
            IsProcessing = false;
            StateHasChanged();
        }
    }

    // ── Auto-download ──
    private bool IsAutoDownloading;
    private string AutoDownloadStatus = "";

    private async Task AutoDownload()
    {
        IsAutoDownloading = true;
        ErrorMessage = null;
        CurrentSteps[0].Status = "active";
        StateHasChanged();

        try
        {
            // Step 1: Download Rimac (siniestros)
            AutoDownloadStatus = "Descargando Rimac...";
            StateHasChanged();
            var rimac = await AutoDownloader.DescargarRimacAsync(s =>
            {
                AutoDownloadStatus = s;
                InvokeAsync(StateHasChanged);
            });

            if (!rimac.Success)
            {
                ErrorMessage = rimac.Error;
                CurrentSteps[0].Status = "error";
                return;
            }
            CurrentSteps[0].Status = "done";
            SiniestrosBytes = rimac.FileBytes;
            SiniestrosFileName = rimac.FileName;

            // Step 2: Download La Positiva (midagri)
            CurrentSteps[1].Status = "active";
            AutoDownloadStatus = "Descargando La Positiva...";
            StateHasChanged();
            var lp = await AutoDownloader.DescargarLaPositivaAsync(s =>
            {
                AutoDownloadStatus = s;
                InvokeAsync(StateHasChanged);
            });

            if (!lp.Success)
            {
                ErrorMessage = lp.Error;
                CurrentSteps[1].Status = "error";
                return;
            }
            CurrentSteps[1].Status = "done";
            MidagriBytes = lp.FileBytes;
            MidagriFileName = lp.FileName;

            // Step 3: Process
            CurrentSteps[2].Status = "active";
            AutoDownloadStatus = "Procesando datos...";
            StateHasChanged();
            await ProcessData();
            DataSource = "auto";
        }
        catch (Exception ex)
        {
            ErrorMessage = $"Error auto-download: {ex.Message}";
        }
        finally
        {
            IsAutoDownloading = false;
            StateHasChanged();
        }
    }

    private void ResetData()
    {
        SharedDatos = null;
        Infrastructure.PythonApi.PythonApiReportService.ClearUploadedFiles();
        UpdateTimestamp = null;
        DataSource = null;
        MidagriBytes = null;
        SiniestrosBytes = null;
        MidagriFileName = null;
        SiniestrosFileName = null;
        ErrorMessage = null;
        CurrentSteps = new()
        {
            new() { Label = "Archivo MIDAGRI", Status = "pending" },
            new() { Label = "Archivo Siniestros", Status = "pending" },
            new() { Label = "Procesando", Status = "pending" },
            new() { Label = "Listo", Status = "pending" },
        };
    }
}

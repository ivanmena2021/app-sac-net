@page "/mapa-calor"
@rendermode InteractiveServer
@using WebApp.Components.Custom

<PageTitle>Mapa de Calor — SAC</PageTitle>

<PageHeader Title="🗺️ Mapa de Calor" Description="Distribución geográfica de siniestros del SAC" />

@if (Home.SharedDatos == null)
{
    <div class="alert alert-warning">⚠️ Primero cargue los datos en la página de <a href="/">Inicio</a>.</div>
}
else
{
    var datos = Home.SharedDatos;

    <div class="row mt-3">
        <div class="col-md-3">
            <MetricCard Label="Departamentos con avisos" Value="@datos.DepartamentosList.Count.ToString()" Accent="blue" />
        </div>
        <div class="col-md-3">
            <MetricCard Label="Total Avisos" Value="@datos.Metricas.TotalAvisos.ToString("N0")" Accent="amber" />
        </div>
        <div class="col-md-3">
            <MetricCard Label="Mayor Indemnización" Value="@($"S/ {datos.Cuadro2.Where(r => r.Departamento != "TOTAL").MaxBy(r => r.MontoIndemnizado)?.MontoIndemnizado ?? 0:N0}")" Accent="red" />
        </div>
        <div class="col-md-3">
            <MetricCard Label="Deptos con Desembolso" Value="@datos.Metricas.DeptosConDesembolso.ToString()" Accent="green" />
        </div>
    </div>

    <!-- Ranking table as proxy for map -->
    <h5 class="mt-4">Ranking por Departamento — Avisos de Siniestro</h5>
    <div class="table-responsive" style="max-height: 500px; overflow-y: auto;">
        <table class="table table-sm table-striped table-bordered">
            <thead class="table-primary sticky-top">
                <tr><th>#</th><th>Departamento</th><th>Avisos</th><th>Ha Indemnizadas</th><th>Indemnización (S/)</th><th>Desembolso (S/)</th></tr>
            </thead>
            <tbody>
                @{ int rank = 1; }
                @foreach (var r in datos.Cuadro2.Where(r => r.Departamento != "TOTAL").OrderByDescending(r => r.MontoIndemnizado))
                {
                    <tr>
                        <td>@(rank++)</td>
                        <td>@System.Globalization.CultureInfo.CurrentCulture.TextInfo.ToTitleCase(r.Departamento.ToLower())</td>
                        <td class="text-end">@datos.Midagri.Count(s => s.Departamento == r.Departamento)</td>
                        <td class="text-end">@r.HaIndemnizadas.ToString("N2")</td>
                        <td class="text-end">@r.MontoIndemnizado.ToString("N2")</td>
                        <td class="text-end">@r.MontoDesembolsado.ToString("N2")</td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="alert alert-info mt-3">
        🗺️ La visualización interactiva de mapas con Plotly se habilitará en una actualización futura.
    </div>
}

<SacFooter />
